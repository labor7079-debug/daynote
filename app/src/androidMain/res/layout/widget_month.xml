<?xml version="1.0" encoding="utf-8"?>
<!--
  DayNote 월 그리드 위젯 — 좌: 미니 월 달력(요일 헤더 + 6주 그리드, 코드에서 채움),
  우: 오늘 날짜(+공휴일명)와 그날의 메모·할 일 4줄. 삼성 캘린더 위젯 컨셉.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_month_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg"
    android:padding="10dp">

    <!-- 좌: 미니 월 달력 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_month_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/widgetText"
            android:paddingBottom="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView style="@style/WidgetDow" android:text="월" />
            <TextView style="@style/WidgetDow" android:text="화" />
            <TextView style="@style/WidgetDow" android:text="수" />
            <TextView style="@style/WidgetDow" android:text="목" />
            <TextView style="@style/WidgetDow" android:text="금" />
            <TextView style="@style/WidgetDow" android:text="토" />
            <TextView
                style="@style/WidgetDow"
                android:text="일"
                android:textColor="@color/widgetAccent" />
        </LinearLayout>

        <!-- 6주 그리드가 남은 높이를 전부 차지 — 행(widget_month_row)이 weight 로 균등 분할돼
             위젯을 늘리거나 줄여도 달력이 잘리거나 위로 압축되지 않는다. -->
        <LinearLayout
            android:id="@+id/widget_month_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical" />
    </LinearLayout>

    <!-- 우: 오늘의 항목 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.9"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_month_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/widgetText" />

            <TextView
                android:id="@+id/widget_month_add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="2dp"
                android:text="＋"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/widgetText" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_month_holiday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/widgetAccent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_mline1"
            style="@style/WidgetLine" />

        <TextView
            android:id="@+id/widget_mline2"
            style="@style/WidgetLine" />

        <TextView
            android:id="@+id/widget_mline3"
            style="@style/WidgetLine" />

        <TextView
            android:id="@+id/widget_mline4"
            style="@style/WidgetLine" />

        <TextView
            android:id="@+id/widget_month_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="serif"
            android:textSize="11sp"
            android:textColor="@color/widgetTextDim"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_month_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="메모·할 일 없음"
            android:fontFamily="serif"
            android:textSize="11sp"
            android:textColor="@color/widgetTextDim"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
