<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 할 일 마감 알림 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 캘린더성 앱의 정확 알람(정시 알림). Play 정책상 캘린더/알람 앱에 허용. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".DayNoteApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DayNote">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden"
            android:theme="@style/Theme.DayNote">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 예약 시각에 알림을 띄우는 리시버(앱 내부에서만 트리거). -->
        <receiver
            android:name=".notification.ReminderReceiver"
            android:exported="false" />

        <!-- 재부팅 후 알람 재예약. -->
        <receiver
            android:name=".notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 홈 화면 위젯 — 오늘의 메모·할 일. -->
        <receiver
            android:name=".widget.DayNoteWidgetProvider"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_daynote_info" />
        </receiver>

        <!-- 홈 화면 위젯(월 그리드) — 미니 월 달력 + 오늘의 항목. -->
        <receiver
            android:name=".widget.DayNoteMonthWidgetProvider"
            android:exported="true"
            android:label="DayNote 월 달력">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_month_info" />
        </receiver>
    </application>

</manifest>
